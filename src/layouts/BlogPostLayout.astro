---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  readTime: string;
}

const { title, description, pubDate, readTime } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<BaseLayout title={`${title} — Susham Yerabolu`} description={description}>
  <article class="blog-post">
    <h1 class="blog-post__title">{title}</h1>
    <div class="blog-post__meta">
      <span>{formattedDate}</span>
      <span> &middot; {readTime}</span>
    </div>
    <div class="blog-post__content">
      <slot />
    </div>
  </article>
</BaseLayout>
